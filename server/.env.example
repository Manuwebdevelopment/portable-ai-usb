# === PORTABLE AI USB — Environment Configuration ===

# Ollama connection
OLLAMA_HOST=http://localhost:11434

# Server settings
HOST=0.0.0.0
PORT=8080

# Default model (must be installed in Ollama first)
DEFAULT_MODEL=qwen2.5:7b

# Response settings
MAX_TOKENS=4096
TEMPERATURE=0.7

# Conversation settings
MAX_HISTORY_SIZE=50
SYSTEM_PROMPT=You are a helpful AI assistant running on a portable USB drive.

# Security
RATE_LIMIT_RPM=30
DEEP_THINKING_ENABLED=false

# Ollama timeout (seconds)
OLLAMA_TIMEOUT=120
